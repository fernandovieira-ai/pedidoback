# ==============================================
# CONFIGURAÇÕES DO SERVIDOR
# ==============================================
# Porta do servidor (Railway vai definir automaticamente)
PORT=3001

# Ambiente de execução
NODE_ENV=production

# IP de bind (0.0.0.0 permite acesso externo)
HOST=0.0.0.0

# ==============================================
# CONFIGURAÇÕES DO BANCO DE DADOS POSTGRESQL
# ==============================================
DB_HOST=cloud.digitalrf.com.br
DB_PORT=5432
DB_NAME=drfpedido
DB_USER=drfpedido
DB_PASSWORD=SUA_SENHA_AQUI

# ==============================================
# CONFIGURAÇÕES DE SEGURANÇA
# ==============================================
# Lista de origens permitidas para CORS (separadas por vírgula)
# Use * para permitir todas as origens ou especifique domínios
CORS_ORIGINS=*

# ==============================================
# INFORMAÇÕES DO SERVIDOR
# ==============================================
# IP público do servidor (Railway vai fornecer um domínio)
SERVER_PUBLIC_IP=seu-app.railway.app
